@model List<PublicWeb.Models.Public.StandingsRowViewModel>
@{
    var league = ViewBag.League as PublicWeb.Models.Public.LeagueViewModel;
    ViewData["Title"] = "Tabla de posiciones - " + league?.Name;
}

<div class="card mb-4 shadow-sm border-0 bg-white">
    <div class="card-body py-4">
        <h2 class="fw-bold mb-1">@league?.Name</h2>
        <p class="text-muted mb-0">@league?.Country</p>
    </div>
</div>

<ul class="nav nav-pills mb-4 nav-fill bg-white p-2 border rounded shadow-sm">
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug">Resumen</a>
    </li>
    <li class="nav-item">
        <a class="nav-link active fw-bold" href="/liga/@league?.Slug/tabla">Tabla de posiciones</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug/resultados">Resultados</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug/fixture">Próximos partidos</a>
    </li>
</ul>

<div class="card shadow-sm">
    <div class="card-header bg-white fw-bold">
        Tabla de Posiciones
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" style="width: 50px;">Pos</th>
                        <th scope="col" class="text-start">Equipo</th>
                        <th scope="col" title="Partidos Jugados">PJ</th>
                        <th scope="col" title="Partidos Ganados">G</th>
                        <th scope="col" title="Partidos Empatados">E</th>
                        <th scope="col" title="Partidos Perdidos">P</th>
                        <th scope="col" title="Goles a Favor">GF</th>
                        <th scope="col" title="Goles en Contra">GC</th>
                        <th scope="col" title="Diferencia de Gol">DG</th>
                        <th scope="col" title="Puntos" class="fw-bold bg-primary text-white">PTS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var row in Model)
                        {
                            <tr>
                                <td class="fw-bold">@row.Position</td>
                                <td class="text-start">
                                    <a href="/equipo/@row.Team.Slug" class="text-decoration-none fw-bold text-dark">
                                        @row.Team.Name
                                    </a>
                                </td>
                                <td>@row.Played</td>
                                <td>@row.Won</td>
                                <td>@row.Drawn</td>
                                <td>@row.Lost</td>
                                <td>@row.GoalsFor</td>
                                <td>@row.GoalsAgainst</td>
                                <td>@row.GoalDifference</td>
                                <td class="fw-bold fs-5 text-primary">@row.Points</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center p-4 text-muted">Aún no hay datos de posiciones.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

