@model PublicWeb.Models.Public.SeasonGroupedViewModel<PublicWeb.Models.Public.MatchdayGroupViewModel>
@{
    var league = ViewBag.League as PublicWeb.Models.Public.LeagueViewModel;
    var seasons = ViewBag.Seasons as List<PublicWeb.Models.Public.SeasonViewModel>;
    
    var selectedSeason = seasons?.FirstOrDefault(s => Model != null && Model.SeasonSlug == s.Slug) ?? seasons?.FirstOrDefault();
    var divisions = selectedSeason?.Divisions ?? new();
    
    ViewData["Title"] = "Resultados - " + league?.Name;
}

<div class="card mb-4 shadow-sm border-0 bg-white">
    <div class="card-body py-4">
        <h2 class="fw-bold mb-1">@league?.Name</h2>
        <p class="text-muted mb-0">@league?.Country</p>
    </div>
</div>

<ul class="nav nav-pills mb-4 nav-fill bg-white p-2 border rounded shadow-sm">
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug">Resumen</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug/tabla">Tabla de posiciones</a>
    </li>
    <li class="nav-item">
        <a class="nav-link active fw-bold" href="/liga/@league?.Slug/resultados">Resultados</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug/partidos">Próximos partidos</a>
    </li>
</ul>

@if (seasons != null && seasons.Any())
{
    <form method="get" class="mb-4 d-flex align-items-center bg-white p-3 rounded shadow-sm flex-wrap">
        <div class="d-flex align-items-center me-4 mb-2 mb-md-0">
            <label class="me-2 fw-bold text-dark">Temporada:</label>
            <select name="season" class="form-select w-auto" onchange="this.form.submit()">
                @foreach (var s in seasons)
                {
                    if (Model != null && Model.SeasonSlug == s.Slug)
                    {
                        <option value="@s.Slug" selected>@s.Name</option>
                    }
                    else
                    {
                        <option value="@s.Slug">@s.Name</option>
                    }
                }
            </select>
        </div>
        
        <div class="d-flex align-items-center mb-2 mb-md-0">
            <label class="me-2 fw-bold text-dark">División:</label>
            <select name="division" class="form-select w-auto" onchange="this.form.submit()">
                <option value="all">Todas</option>
                @foreach (var d in divisions)
                {
                    if (ViewBag.Division != null && ViewBag.Division == d.Slug)
                    {
                        <option value="@d.Slug" selected>@d.Name</option>
                    }
                    else
                    {
                        <option value="@d.Slug">@d.Name</option>
                    }
                }
            </select>
        </div>
    </form>
}

<!-- Ad: Above the matchdays navigation -->
@await Html.PartialAsync("_AdSenseBlock", "results_top")

@if (Model != null && Model.Divisions.Any())
{
    foreach (var div in Model.Divisions)
    {
        <h4 class="fw-bold mt-4 mb-3 text-secondary border-bottom pb-2">@div.DivisionName</h4>
        
        @if (div.Data != null && div.Data.Any())
        {
            var requestingRound = ViewBag.Round as int?;
            var activeMatchday = requestingRound.HasValue ? div.Data.FirstOrDefault(m => m.Round == requestingRound) : div.Data.FirstOrDefault();
            if (activeMatchday == null) activeMatchday = div.Data.FirstOrDefault();

            var currentRoundNav = activeMatchday?.Round;

            <ul class="nav nav-pills mb-3 overflow-auto flex-nowrap pb-2" style="white-space: nowrap;">
                @foreach (var matchday in div.Data)
                {
                    <li class="nav-item me-2">
                        <a class="nav-link rounded-pill @(matchday.Round == currentRoundNav ? "active" : "bg-light text-dark border")" 
                           href="?season=@Model.SeasonSlug&division=@(ViewBag.Division)&round=@matchday.Round">
                           Fecha @matchday.Round
                        </a>
                    </li>
                }
            </ul>

            <div class="card shadow-sm mb-4 border-0">
                <div class="card-body p-0">
                    @if (activeMatchday != null && activeMatchday.Matches.Any())
                    {
                        <div class="list-group list-group-flush rounded-3">
                        @foreach (var match in activeMatchday.Matches)
                        {
                            <a href="/partido/@match.Id" class="list-group-item list-group-item-action p-3 border-bottom">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">@match.Kickoff.ToString("dd/MM/yyyy HH:mm")</small>
                                    <span class="badge bg-success">Finalizado</span>
                                </div>
                                <div class="row text-center align-items-center fw-bold fs-5">
                                    <div class="col-4 text-end">@match.HomeTeam.Name</div>
                                    <div class="col-4 d-flex justify-content-center">
                                        <span class="bg-light border px-3 py-1 rounded">@match.HomeScore - @match.AwayScore</span>
                                    </div>
                                    <div class="col-4 text-start">@match.AwayTeam.Name</div>
                                </div>
                            </a>
                        }
                        </div>
                        
                        <!-- Ad: Below Matchday Matches -->
                        @await Html.PartialAsync("_AdSenseBlock", "results_below_matches")
                    }
                    else
                    {
                        <div class="p-5 text-center text-muted">
                            No hay resultados en esta fecha.
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="p-4 text-center text-muted">
                No hay resultados registrados en esta división.
            </div>
        }
    }
}
else
{
    <div class="card shadow-sm border-0">
        <div class="p-5 text-center text-muted">No hay resultados recientes para mostrar.</div>
    </div>
}
