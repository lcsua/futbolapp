@model List<PublicWeb.Models.Public.MatchViewModel>
@{
    var league = ViewBag.League as PublicWeb.Models.Public.LeagueViewModel;
    ViewData["Title"] = "Fixture - " + league?.Name;
}

<div class="card mb-4 shadow-sm border-0 bg-white">
    <div class="card-body py-4">
        <h2 class="fw-bold mb-1">@league?.Name</h2>
        <p class="text-muted mb-0">@league?.Country</p>
    </div>
</div>

<ul class="nav nav-pills mb-4 nav-fill bg-white p-2 border rounded shadow-sm">
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug">Resumen</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug/tabla">Tabla de posiciones</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@league?.Slug/resultados">Resultados</a>
    </li>
    <li class="nav-item">
        <a class="nav-link active fw-bold" href="/liga/@league?.Slug/fixture">Próximos partidos</a>
    </li>
</ul>

<div class="card shadow-sm">
    <div class="card-header bg-white fw-bold">
        Próximos partidos (Fixture)
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="list-group list-group-flush">
            @foreach (var match in Model)
            {
                <div class="list-group-item p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="text-muted">@match.Kickoff.ToString("dd/MM/yyyy HH:mm")</small>
                        <span class="badge bg-secondary">Programado</span>
                    </div>
                    <div class="row text-center align-items-center fw-bold fs-5">
                        <div class="col-4 text-end">@match.HomeTeam.Name</div>
                        <div class="col-4 text-muted fs-6">
                            vs
                        </div>
                        <div class="col-4 text-start">@match.AwayTeam.Name</div>
                    </div>
                </div>
            }
            </div>
        }
        else
        {
            <div class="p-5 text-center text-muted">
                No hay partidos programados próximamente.
            </div>
        }
    </div>
</div>

