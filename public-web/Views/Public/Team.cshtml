@model PublicWeb.Models.Public.TeamViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="row mb-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4 text-center">
            <div class="card-body py-5">
                <div class="display-1 text-primary mb-3">🛡️</div>
                <h2>@Model.Name</h2>
                @if(!string.IsNullOrEmpty(Model.ShortName))
                {
                    <p class="text-muted">(@Model.ShortName)</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white fw-bold">Plantel e Información</div>
            <div class="card-body">
                <p>Información del equipo, lista de jugadores y estadísticas aquí.</p>
                @if(Model.FoundedYear.HasValue)
                {
                    <p><strong>Fundado en:</strong> @Model.FoundedYear</p>
                }
            </div>
        </div>
    </div>
</div>

