@{
    ViewData["Title"] = "Planes y Precios";
}

<div class="pricing-header p-3 pb-md-4 mx-auto text-center">
    <h1 class="display-4 fw-normal">Precios transparentes</h1>
    <p class="fs-5 text-muted">Acompañamos el crecimiento de tu liga. Empieza gratis, sube de nivel cuando lo necesites.</p>
</div>

<main>
    <div class="row row-cols-1 row-cols-md-3 mb-3 text-center">
        <div class="col">
            <div class="card mb-4 rounded-3 shadow-sm border-primary">
                <div class="card-header py-3 text-white bg-primary border-primary">
                    <h4 class="my-0 fw-normal">Gratis</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title">$0<small class="text-muted fw-light">/mes</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li>Hasta 16 equipos</li>
                        <li>Tabla de posiciones</li>
                        <li>Fixture automático</li>
                        <li>Publicidad en la página</li>
                    </ul>
                    <a href="/login" class="w-100 btn btn-lg btn-primary">Registrate gratis</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card mb-4 rounded-3 shadow-sm">
                <div class="card-header py-3">
                    <h4 class="my-0 fw-normal">Pro</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title">$15<small class="text-muted fw-light">/mes</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li>Equipos ilimitados</li>
                        <li>Múltiples categorías</li>
                        <li>Sin publicidad (opcional)</li>
                        <li>Estadísticas de goleadores</li>
                    </ul>
                    <a href="/login" class="w-100 btn btn-lg btn-outline-primary">Comenzar prueba gratis</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card mb-4 rounded-3 shadow-sm">
                <div class="card-header py-3">
                    <h4 class="my-0 fw-normal">Premium</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title">$40<small class="text-muted fw-light">/mes</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li>Todo lo del plan Pro</li>
                        <li>Soporte prioritario 24/7</li>
                        <li>Dominio personalizado</li>
                        <li>Gestión de pagos manuales</li>
                    </ul>
                    <button type="button" class="w-100 btn btn-lg btn-outline-primary">Contactarnos</button>
                </div>
            </div>
        </div>
    </div>
</main>

