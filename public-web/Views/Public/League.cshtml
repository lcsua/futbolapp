@model PublicWeb.Models.Public.LeagueViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="card mb-4 shadow-sm border-0 bg-white">
    <div class="card-body py-4">
        <h2 class="fw-bold mb-1">@Model.Name</h2>
        <p class="text-muted mb-0"><i class="bi bi-geo-alt"></i> @Model.Country</p>
    </div>
</div>

<ul class="nav nav-pills mb-4 nav-fill bg-white p-2 border rounded shadow-sm">
    <li class="nav-item">
        <a class="nav-link active fw-bold" href="/liga/@Model.Slug">Resumen</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@Model.Slug/tabla">Tabla de posiciones</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@Model.Slug/resultados">Resultados</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/liga/@Model.Slug/fixture">Próximos partidos</a>
    </li>
</ul>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white fw-bold">Acerca de la liga</div>
            <div class="card-body">
                <p>@Model.Description</p>
                <div class="alert alert-info">¡Bienvenido a la página oficial de @Model.Name! Aquí podrás seguir todo el torneo.</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        @if (ViewData["HideAds"] == null || !(bool)ViewData["HideAds"])
        {
            <div class="card text-center mb-4 border-0 bg-light p-4">
                <small class="text-muted">Espacio publicitario (300x250)</small>
            </div>
        }
    </div>
</div>

