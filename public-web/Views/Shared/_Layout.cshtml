<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LigApp</title>
    
    <!-- SEO and OpenGraph -->
    <meta name="description" content="@(ViewData["Description"] ?? "Gestiona tu liga de fútbol fácilmente con resultados, tabla y fixture automático.")" />
    <meta property="og:title" content="@ViewData["Title"] - LigApp" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "LigApp es la plataforma número uno para la gestión de ligas de fútbol amateur.")" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.ligapp.com" />
    
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6942296606634637" crossorigin="anonymous"></script>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">LigApp ⚽</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" href="/">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/precios">Precios</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="btn btn-outline-light me-2" href="/login">Iniciar sesión</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-warning fw-bold text-dark" href="/login">Crear liga</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Ad placeholder superior -->
    @if (ViewData["HideAds"] == null || !(bool)ViewData["HideAds"])
    {
        @await Html.PartialAsync("_AdSenseBlock", "top_global_banner")
    }

    <div class="container flex-grow-1 mb-5 mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white border-top footer mt-auto py-3">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - LigApp - <a href="#" class="text-white text-decoration-none">Privacidad</a> | <a href="#" class="text-white text-decoration-none">Términos</a>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

